# Server
PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# Surplus upstream
SURPLUS_BASE_URL=https://api.surplusintelligence.ai/v1
SURPLUS_API_KEY=replace-me

# Router behavior
ROUTER_MODEL_IDS=surplus-smart-router,auto
CAPABILITY_REGISTRY_PATH=./registry/models.json
SQLITE_PATH=./data/router.sqlite
CACHE_TTL_MS=60000
REQUEST_TIMEOUT_MS=120000

# Auto-reload the capability registry when the file changes (true/false)
REGISTRY_WATCH=true

# Utility weights must add up to approximately 1.0.
UTILITY_WEIGHTS={"capability":0.45,"cost":0.25,"latency":0.10,"history":0.10,"preferences":0.10}

# Optional JSON. Examples:
# USER_PREFERENCES={"preferModels":["claude-sonnet-5"],"avoidModels":["expensive-model"],"maxInputCostPerMTok":5,"maxOutputCostPerMTok":25,"latencyBias":"balanced"}
USER_PREFERENCES={}
